        para corregirlos. "
      objectReference: {fileID: 0}
    - target: {fileID: 1961146443698051630, guid: 76b3b34d380dcec4e974ca0f283c4f6c, type: 3}
      propertyPath: dialogos.Array.data[1].texto
      value: Recuerda que la seguridad es un compromiso de todos.
