      propertyPath: dialogos.Array.data[0].texto
      value: "Nivel completado. Has demostrado que sabes elegir y utilizar los elementos
        que protegen tu vida. En Carvajal, el uso de protecci\xF3n no es negociable;
        es tu mejor defensa."
      objectReference: {fileID: 0}
    - target: {fileID: 1961146443698051630, guid: 76b3b34d380dcec4e974ca0f283c4f6c, type: 3}
      propertyPath: dialogos.Array.data[1].texto
      value: Para este nivel debes acercarte a los diferentes riesgos que hay alrededor
        del mapa.
      objectReference: {fileID: 0}
    - target: {fileID: 1961146443698051630, guid: 76b3b34d380dcec4e974ca0f283c4f6c, type: 3}
      propertyPath: dialogos.Array.data[2].texto
