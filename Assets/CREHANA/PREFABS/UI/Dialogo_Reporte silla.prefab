    - target: {fileID: 2306703872159387378, guid: 2e488c1aba17f78469a9ade1d801d724, type: 3}
      propertyPath: dialogos.Array.data[0].texto
      value: "\xA1Postura asegurada! Has reemplazado la silla por un asiento ergon\xF3mico.
        Mantener un apoyo adecuado en la espalda previene lesiones y fatiga durante
        tu jornada. "
      objectReference: {fileID: 0}
    - target: {fileID: 2306703872159387378, guid: 2e488c1aba17f78469a9ade1d801d724, type: 3}
      propertyPath: dialogos.Array.data[1].texto
      value: "Despl\xE1zate con las flechas del teclado si estas en el computador,
        o los botones t\xE1ctiles si estas en celular. "
      objectReference: {fileID: 0}
    - target: {fileID: 2306703872159387378, guid: 2e488c1aba17f78469a9ade1d801d724, type: 3}
